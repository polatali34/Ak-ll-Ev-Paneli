@model MovieApp.Web.Models.HomeStatus

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <script>
        (function () {
            try {
                if (localStorage.getItem('theme') === 'night') {
                    document.documentElement.classList.add('night-mode');
                    document.documentElement.style.backgroundColor = '#0f172a';
                }
            } catch (e) {
                console.log("Tema okunamadı:", e);
            }
        })();
    </script>

    <title>Akıllı Ev Kontrol Paneli</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --bg-color: #f0f3f8;
            --sidebar-bg: #ffffff;
            --card-bg: #ffffff;
            --dark-card-bg: #151a26;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --primary-blue: #3b82f6;
            --success-green: #10b981;
            --danger-red: #ef4444;
            --warning-yellow: #f59e0b;
            --border-color: #e2e8f0;
        }

        html {
            background-color: #f0f3f8;
        }

        html.night-mode {
            background-color: #0f172a;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        html, body {
            width: 100%;
            height: 100%;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        html.night-mode body {
            --bg-color: #0f172a;
            --sidebar-bg: #111827;
            --card-bg: #1e293b;
            --dark-card-bg: #020617;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --border-color: #334155;
            background-color: #0f172a;
        }

        html.night-mode .panel-title h2,
        html.night-mode .big-value,
        html.night-mode h4,
        html.night-mode .section-heading h3,
        html.night-mode .room-title {
            color: #f8fafc !important;
        }

        html.night-mode .card,
        html.night-mode .footer-bar,
        html.night-mode .sidebar,
        html.night-mode .room-card,
        html.night-mode .scene-card,
        html.night-mode .sensor-detail-card,
        html.night-mode .settings-card {
            background-color: var(--card-bg);
            border-color: var(--border-color);
        }

        html.night-mode .top-bar {
            background: #020617;
        }

        html.night-mode .light-mini-card {
            background: #334155;
            border-color: #475569;
        }

        html.night-mode .light-mini-card.off {
            background: #111827;
            border-color: #334155;
        }

        html.night-mode .btn-perde-preset,
        html.night-mode .panel-theme-btn,
        html.night-mode .room-preset-btn,
        html.night-mode .scene-btn {
            background: #334155 !important;
            color: #f8fafc !important;
            border-color: #475569 !important;
        }

        html.night-mode .btn-perde-preset:hover,
        html.night-mode .room-preset-btn:hover,
        html.night-mode .scene-btn:hover {
            background: #475569 !important;
        }

        html.night-mode .range-slider,
        html.night-mode .room-range {
            background: #334155;
        }

        html.night-mode .footer-bar {
            color: #94a3b8;
        }

        html.night-mode .nav-item.active {
            background-color: #1e3a8a;
            color: #bfdbfe;
        }

        html.night-mode .counter-group {
            background: #111827;
        }

        html.night-mode .btn-circle,
        html.night-mode .btn-preset {
            background: #334155;
        }

        html.night-mode .btn-preset.active {
            background: #3b82f6;
        }

        html.night-mode .empty-panel {
            background: #111827;
            border-color: #334155;
        }

        .top-bar {
            position: absolute;
            top: 0;
            left: 80px;
            right: 0;
            height: 40px;
            background: #0f172a;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
            font-size: 0.8rem;
            z-index: 100;
        }

        .sidebar {
            width: 80px;
            background-color: var(--sidebar-bg);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-top: 60px;
            justify-content: space-between;
            padding-bottom: 20px;
            z-index: 90;
        }

        .nav-item {
            width: 58px;
            height: 58px;
            border-radius: 14px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            cursor: pointer;
            margin-bottom: 15px;
            font-size: 0.7rem;
            gap: 5px;
            transition: 0.2s;
            border: 1px solid transparent;
        }

        .nav-item:hover {
            background-color: rgba(59, 130, 246, 0.08);
            color: var(--primary-blue);
        }

        .nav-item.active {
            background-color: #e0e7ff;
            color: var(--primary-blue);
            border-left: 4px solid var(--primary-blue);
            border-radius: 4px 14px 14px 4px;
        }

        .nav-item i {
            font-size: 1.25rem;
        }

        .main-container {
            flex: 1;
            padding: 60px 25px 110px 25px;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
        }

        .panel-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-shrink: 0;
        }

        .panel-title h2 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #0f172a;
        }

        .panel-title p {
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .page-section {
            display: none;
        }

        .page-section.active {
            display: block;
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            grid-template-rows: 280px 280px;
            gap: 20px;
            flex: none;
            align-items: stretch;
            padding-bottom: 35px;
        }

        .card {
            background-color: var(--card-bg);
            border-radius: 20px;
            padding: 20px;
            box-shadow: 0 4px 18px rgba(0,0,0,0.03);
            border: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            position: relative;
            height: 100%;
            min-height: 280px;
            overflow: hidden;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 15px;
            flex-shrink: 0;
        }

        .badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            white-space: nowrap;
        }

        .badge-success {
            background: #e6f4ea;
            color: #137333;
        }

        .badge-danger {
            background: #fce8e6;
            color: #c5221f;
        }

        .badge-info {
            background: #e8f0fe;
            color: #1a73e8;
        }

        .big-value {
            font-size: 3rem;
            font-weight: 700;
            color: #0f172a;
            margin-top: 10px;
        }

        .big-value span {
            font-size: 1.2rem;
            font-weight: 500;
            color: var(--text-muted);
        }

        .sparkline {
            width: 100%;
            height: 50px;
            margin-top: 10px;
            flex-shrink: 0;
        }

        .dark-card {
            background-color: var(--dark-card-bg);
            color: #fff;
            border: none;
        }

        .dark-card .big-value {
            color: #fff;
        }

        .motor-form {
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            margin: 0;
        }

        .motor-state-area {
            min-height: 145px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .counter-group {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            margin: 15px 0;
            background: #1e2538;
            padding: 10px;
            border-radius: 12px;
        }

        .btn-circle {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            border: none;
            background: #2a344d;
            color: #fff;
            font-size: 1.2rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .motor-presets {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
            margin-bottom: 15px;
        }

        .btn-preset {
            background: #2a344d;
            border: none;
            color: #94a3b8;
            padding: 8px;
            border-radius: 8px;
            font-size: 0.8rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 4px;
        }

        .btn-preset.active {
            background: #3b82f6;
            color: white;
        }

        .btn-main {
            width: 100%;
            background: #3b82f6;
            color: white;
            border: none;
            padding: 14px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: 0.2s;
            flex-shrink: 0;
        }

        .btn-main:hover {
            background: #2563eb;
        }

        .light-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
            margin-top: 5px;
            flex: 1;
        }

        .light-mini-card {
            background: #fffbeb;
            border: 1px solid #fef3c7;
            border-radius: 14px;
            padding: 12px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            cursor: pointer;
            transition: 0.2s;
            position: relative;
            overflow: hidden;
            min-height: 78px;
        }

        .light-mini-card.off {
            background: #f8fafc;
            border-color: #e2e8f0;
        }

        .light-mini-card:hover {
            transform: translateY(-2px);
        }

        .card-bg-icon {
            position: absolute;
            bottom: -10px;
            right: -10px;
            font-size: 3rem;
            color: @(Model.IsTavanLightOn ? "rgba(245, 158, 11, 0.1)" : "rgba(148, 163, 184, 0.1)");
        }

        .slider-container {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-top: 20px;
        }

        .range-slider {
            flex: 1;
            height: 6px;
            -webkit-appearance: none;
            background: #e2e8f0;
            border-radius: 50px;
            outline: none;
        }

        .range-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: var(--primary-blue);
            cursor: pointer;
        }

        .perde-presets {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 5px;
            margin-top: 15px;
        }

        .btn-perde-preset {
            background: #f1f5f9;
            border: none;
            font-size: 0.75rem;
            padding: 8px 4px;
            border-radius: 8px;
            cursor: pointer;
            text-align: center;
            font-weight: 500;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 4px;
        }

        .btn-perde-preset:hover {
            background: #e2e8f0;
        }

        .section-heading {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 18px;
        }

        .section-heading h3 {
            color: #0f172a;
            font-size: 1.25rem;
        }

        .section-heading p {
            color: var(--text-muted);
            font-size: 0.85rem;
            margin-top: 4px;
        }

        .section-actions {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .quick-form {
            margin: 0;
        }

        .quick-btn {
            border: 1px solid var(--border-color);
            background: #fff;
            border-radius: 10px;
            padding: 9px 14px;
            cursor: pointer;
            font-weight: 600;
            color: var(--text-main);
        }

        .quick-btn.blue {
            background: var(--primary-blue);
            border-color: var(--primary-blue);
            color: #fff;
        }

        .quick-btn.red {
            background: var(--danger-red);
            border-color: var(--danger-red);
            color: #fff;
        }

        .lighting-page-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 20px;
            padding-bottom: 35px;
        }

        .room-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 20px;
            min-height: 215px;
            box-shadow: 0 4px 18px rgba(0,0,0,0.03);
        }

        .room-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 18px;
        }

        .room-title {
            font-size: 1rem;
            font-weight: 700;
            color: #0f172a;
        }

        .room-subtitle {
            font-size: 0.78rem;
            color: var(--text-muted);
            margin-top: 4px;
        }

        .room-icon {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            background: #eff6ff;
            color: var(--primary-blue);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
        }

        .room-percent {
            font-size: 2.6rem;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 10px;
        }

        .room-percent span {
            font-size: 1rem;
            color: var(--text-muted);
            font-weight: 600;
        }

        .room-range-row {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .room-range {
            flex: 1;
            height: 7px;
            -webkit-appearance: none;
            background: #e2e8f0;
            border-radius: 50px;
            outline: none;
        }

        .room-range::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 19px;
            height: 19px;
            border-radius: 50%;
            background: var(--primary-blue);
            cursor: pointer;
        }

        .room-presets {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 7px;
            margin-top: 14px;
        }

        .room-preset-btn {
            border: 1px solid var(--border-color);
            background: #f8fafc;
            color: var(--text-main);
            border-radius: 9px;
            padding: 8px 4px;
            cursor: pointer;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .room-preset-btn:hover {
            background: #e2e8f0;
        }

        .detail-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 20px;
        }

        .sensor-detail-card,
        .scene-card,
        .settings-card,
        .empty-panel {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 22px;
            min-height: 210px;
            box-shadow: 0 4px 18px rgba(0,0,0,0.03);
        }

        .scene-btn {
            width: 100%;
            border: 1px solid var(--border-color);
            background: #fff;
            padding: 12px;
            border-radius: 12px;
            margin-top: 10px;
            cursor: pointer;
            font-weight: 600;
            text-align: left;
            color: var(--text-main);
        }

        .footer-bar {
            height: 40px;
            border-top: 1px solid var(--border-color);
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
            font-size: 0.8rem;
            color: var(--text-muted);
            position: fixed;
            bottom: 0;
            left: 80px;
            right: 0;
            z-index: 120;
        }

        @@media (max-width: 1200px) {
            .dashboard-grid,
            .lighting-page-grid,
            .detail-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .dashboard-grid {
                grid-template-rows: none;
                grid-auto-rows: 280px;
            }

            .card[style*="grid-column: span 2"] {
                grid-column: span 2 !important;
            }
        }

        @@media (max-width: 760px) {
            body {
                overflow: auto;
            }

            .top-bar {
                left: 0;
                height: auto;
                min-height: 40px;
                flex-wrap: wrap;
                gap: 8px;
                padding: 8px 12px;
            }

            .sidebar {
                display: none;
            }

            .main-container {
                padding: 85px 15px 110px 15px;
            }

            .panel-header,
            .section-heading {
                align-items: flex-start;
                flex-direction: column;
                gap: 12px;
            }

            .dashboard-grid,
            .lighting-page-grid,
            .detail-grid {
                grid-template-columns: 1fr;
                grid-auto-rows: auto;
            }

            .card,
            .card[style*="grid-column: span 2"] {
                grid-column: span 1 !important;
                min-height: 280px;
            }

            .footer-bar {
                left: 0;
                height: auto;
                min-height: 48px;
                flex-direction: column;
                align-items: flex-start;
                gap: 4px;
                padding: 8px 12px;
            }
        }
    </style>
</head>

<body>

    <div class="top-bar">
        <div>
            <i class="fa-solid fa-cloud-sun"></i> 22°C Dış
            &nbsp;|&nbsp;
            <i class="fa-solid fa-wifi"></i> %87
        </div>

        <div>
            <i class="fa-solid fa-circle" style="color: #10b981; font-size: 0.6rem;"></i>
            HUB CONNECTED
            <span style="opacity:0.5; margin-left:10px;">v2.4.1</span>
        </div>

        <div>
            <i class="fa-solid fa-calendar-alt"></i>
            <span id="dateText"></span>
            &nbsp;|&nbsp;
            <i class="fa-solid fa-clock"></i>
            <span id="clock"></span>
        </div>
    </div>

    <div class="sidebar">
        <div>
            <div id="nav-general" class="nav-item active" onclick="showSection('general')">
                <i class="fa-solid fa-house"></i>Genel
            </div>

            <div id="nav-sensor" class="nav-item" onclick="showSection('sensor')">
                <i class="fa-solid fa-temperature-half"></i>Sensör
            </div>

            <div id="nav-lighting" class="nav-item" onclick="showSection('lighting')">
                <i class="fa-solid fa-lightbulb"></i>Aydınlatma
            </div>

            <div id="nav-scene" class="nav-item" onclick="showSection('scene')">
                <i class="fa-solid fa-wand-magic-sparkles"></i>Sahne
            </div>

            <div id="nav-energy" class="nav-item" onclick="showSection('energy')">
                <i class="fa-solid fa-bolt"></i>Enerji
            </div>
        </div>

        <div id="nav-settings" class="nav-item" onclick="showSection('settings')">
            <i class="fa-solid fa-gear"></i>Ayar
        </div>
    </div>

    <div class="main-container">
        <div class="panel-header">
            <div class="panel-title">
                <h2 id="panelTitle">Akıllı Ev Kontrol Paneli</h2>
                <p id="panelSubtitle">
                    Oturma Odası · 4 cihaz aktif · Otomasyon:
                    <span style="color:var(--success-green); font-weight:600;">
                        <i class="fa-solid fa-circle-check"></i> Açık
                    </span>
                </p>
            </div>

            <div style="display:flex; gap:10px;">
                <button type="button" onclick="setTheme('day')" class="panel-theme-btn" style="padding: 8px 16px; border-radius: 8px; border: 1px solid #e2e8f0; background:#fff; cursor:pointer;">
                    <i class="fa-solid fa-sun" style="color:#f59e0b;"></i> Gündüz
                </button>

                <button type="button" onclick="setTheme('night')" class="panel-theme-btn" style="padding: 8px 16px; border-radius: 8px; border: 1px solid #e2e8f0; background:#fff; cursor:pointer;">
                    <i class="fa-solid fa-moon" style="color:#3b82f6;"></i> Gece
                </button>
            </div>
        </div>

        <section id="section-general" class="page-section active">
            <div class="dashboard-grid">

                <div class="card">
                    <div class="card-header">
                        <div>
                            <p style="font-size:0.75rem; color:var(--text-muted); font-weight:700;">
                                <i class="fa-solid fa-temperature-low"></i> SENSÖR
                            </p>
                            <h4 style="font-size:0.95rem;">Ortam Sıcaklığı</h4>
                        </div>

                        <span class="badge badge-success">
                            <i class="fa-solid fa-check-circle"></i> NORMAL
                        </span>
                    </div>

                    <svg class="sparkline" viewBox="0 0 100 30">
                        <path d="M0 20 Q 25 15, 50 18 T 100 12" fill="none" stroke="#ef4444" stroke-width="2" />
                    </svg>

                    <div class="big-value">
                        @Model.Temperature<span>°C</span>
                    </div>

                    <p style="font-size:0.75rem; color:var(--text-muted); margin-top:auto;">
                        <i class="fa-solid fa-bullseye"></i> Hedef: 22,0°C
                        <span style="float:right;">
                            <i class="fa-solid fa-thermometer-three-quarters"></i> Min/Max: 21,2 / 24,1
                        </span>
                    </p>
                </div>

                <div class="card">
                    <div class="card-header">
                        <div>
                            <p style="font-size:0.75rem; color:var(--text-muted); font-weight:700;">
                                <i class="fa-solid fa-droplet"></i> SENSÖR
                            </p>
                            <h4 style="font-size:0.95rem;">Ortam Nemi</h4>
                        </div>

                        <span class="badge badge-info">
                            <i class="fa-solid fa-heart-pulse"></i> KONFOR
                        </span>
                    </div>

                    <svg class="sparkline" viewBox="0 0 100 30">
                        <path d="M0 15 Q 25 18, 50 12 T 100 14" fill="none" stroke="#3b82f6" stroke-width="2" />
                    </svg>

                    <div class="big-value">
                        @Model.Humidity<span>%RH</span>
                    </div>

                    <p style="font-size:0.75rem; color:var(--text-muted); margin-top:auto;">
