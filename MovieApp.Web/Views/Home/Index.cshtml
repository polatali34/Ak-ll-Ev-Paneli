                <div class="sensor-detail-card">
                    <p style="color:var(--text-muted); font-weight:700;">BAĞLANTI</p>
                    <div class="big-value" style="font-size:2rem;">@Model.ConnectionQuality</div>
                    <p style="color:var(--text-muted); margin-top:10px;">Son eşitleme: @Model.LastSyncTime</p>
                </div>
            </div>
        </section>

        <section id="section-scene" class="page-section">
            <div class="section-heading">
                <div>
                    <h3><i class="fa-solid fa-wand-magic-sparkles"></i> Sahne Modları</h3>
                    <p>Hazır modlarla panel görünümünü ve kullanım şeklini değiştir.</p>
                </div>
            </div>

            <div class="detail-grid">
                <div class="scene-card">
                    <h4><i class="fa-solid fa-sun" style="color:#f59e0b;"></i> Gündüz Modu</h4>
                    <p style="color:var(--text-muted); margin-top:8px;">Paneli açık temaya alır.</p>
                    <button type="button" class="scene-btn" onclick="setTheme('day')">
                        <i class="fa-solid fa-play"></i> Gündüz Modunu Başlat
                    </button>
                </div>

                <div class="scene-card">
                    <h4><i class="fa-solid fa-moon" style="color:#3b82f6;"></i> Gece Modu</h4>
                    <p style="color:var(--text-muted); margin-top:8px;">Paneli koyu temaya alır.</p>
                    <button type="button" class="scene-btn" onclick="setTheme('night')">
                        <i class="fa-solid fa-play"></i> Gece Modunu Başlat
                    </button>
                </div>

                <div class="scene-card">
    <h4><i class="fa-solid fa-tv" style="color:#8b5cf6;"></i> Film Modu</h4>

    <p style="color:var(--text-muted); margin-top:8px;">
        Perde kapanır, motor durur, ortam loş moda geçer ve panel gece temasına alınır.
    </p>

    <div style="margin-top:14px; display:grid; grid-template-columns: repeat(2, 1fr); gap:8px; font-size:0.78rem; color:var(--text-muted);">
        <div><i class="fa-solid fa-window-maximize"></i> Perde: Kapalı</div>
        <div><i class="fa-solid fa-fan"></i> Motor: Kapalı</div>
        <div><i class="fa-solid fa-lightbulb"></i> Salon: %20</div>
        <div><i class="fa-solid fa-road"></i> Koridor: %15</div>
    </div>

    <form action="/Home/ApplyMovieMode" method="post" style="margin:0;" onsubmit="activateMovieModeBeforeSubmit()">
        <button type="submit" class="scene-btn" style="background:#8b5cf6; color:#fff; border-color:#8b5cf6;">
            <i class="fa-solid fa-play"></i> Film Modunu Başlat
        </button>
    </form>
</div>
        </section>

        <section id="section-energy" class="page-section">
            <div class="section-heading">
                <div>
                    <h3><i class="fa-solid fa-bolt"></i> Enerji Takibi</h3>
                    <p>Günlük tüketim ve cihaz durumları.</p>
                </div>
            </div>

            <div class="detail-grid">
                <div class="sensor-detail-card">
                    <p style="color:var(--text-muted); font-weight:700;">BUGÜN</p>
                    <div class="big-value">3,2<span>kWh</span></div>
                    <p style="color:var(--text-muted); margin-top:10px;">Tahmini günlük tüketim.</p>
                </div>

                <div class="sensor-detail-card">
                    <p style="color:var(--text-muted); font-weight:700;">AKTİF CİHAZ</p>
                    <div class="big-value">4<span>adet</span></div>
                    <p style="color:var(--text-muted); margin-top:10px;">Panelde aktif görünen cihaz sayısı.</p>
                </div>

                <div class="sensor-detail-card">
                    <p style="color:var(--text-muted); font-weight:700;">UYARI</p>
                    <div class="big-value" style="font-size:2rem; color:var(--success-green);">Yok</div>
                    <p style="color:var(--text-muted); margin-top:10px;">Enerji durumu normal.</p>
                </div>
            </div>
        </section>

        <section id="section-settings" class="page-section">
            <div class="section-heading">
                <div>
                    <h3><i class="fa-solid fa-gear"></i> Ayarlar</h3>
                    <p>Panel ayarları ve sistem bilgileri.</p>
                </div>
            </div>

            <div class="detail-grid">
                <div class="settings-card">
                    <h4>Operatör</h4>
                    <p style="color:var(--text-muted); margin-top:8px;">@Model.OperatorName</p>
                </div>

                <div class="settings-card">
                    <h4>MQTT Broker</h4>
                    <p style="color:var(--text-muted); margin-top:8px;">broker.local:8883</p>
                </div>

                <div class="settings-card">
                    <h4>Son Senkronizasyon</h4>
                    <p style="color:var(--text-muted); margin-top:8px;">@Model.LastSyncTime</p>
                </div>
            </div>
        </section>
    </div>

    <div class="footer-bar">
        <div>
            <i class="fa-solid fa-user-circle"></i> Operatör:
            <strong>@Model.OperatorName</strong>
            &nbsp;|&nbsp;
            <i class="fa-solid fa-satellite-dish"></i> Sinyal:
            <span style="color:var(--success-green);">
                <i class="fa-solid fa-check-double"></i> Mükemmel (-42 dBm)
            </span>
        </div>

        <div>
            <i class="fa-solid fa-network-wired"></i> MQTT:
            <strong><i class="fa-solid fa-unlink"></i> broker.local:8883</strong>
            &nbsp;|&nbsp;
            Bugün: <i class="fa-solid fa-bolt"></i> 3,2 kWh
            &nbsp;|&nbsp;
            Uyarı:
            <span style="color:var(--success-green);">
                <i class="fa-solid fa-check"></i> Yok
            </span>
        </div>
    </div>

    <script>
        function updateDateTime() {
            var now = new Date();

            var days = [
                "Pazar",
                "Pazartesi",
                "Salı",
                "Çarşamba",
                "Perşembe",
                "Cuma",
                "Cumartesi"
            ];

            var months = [
                "Ocak",
                "Şubat",
                "Mart",
                "Nisan",
                "Mayıs",
                "Haziran",
                "Temmuz",
                "Ağustos",
                "Eylül",
                "Ekim",
                "Kasım",
                "Aralık"
            ];

            var day = now.getDate();
            var month = months[now.getMonth()];
            var year = now.getFullYear();
            var weekDay = days[now.getDay()];

            var h = now.getHours();
            var m = now.getMinutes();
            var s = now.getSeconds();

            h = h < 10 ? '0' + h : h;
            m = m < 10 ? '0' + m : m;
            s = s < 10 ? '0' + s : s;

            var dateText = document.getElementById('dateText');
            var clock = document.getElementById('clock');

            if (dateText) {
                dateText.innerHTML = day + " " + month + " " + year + " - " + weekDay;
            }

            if (clock) {
                clock.innerHTML = h + ":" + m + ":" + s;
            }
        }

        function setTheme(mode) {
            if (mode === 'night') {
                document.documentElement.classList.add('night-mode');
                document.documentElement.style.backgroundColor = '#0f172a';
                localStorage.setItem('theme', 'night');
            } else {
                document.documentElement.classList.remove('night-mode');
                document.documentElement.style.backgroundColor = '#f0f3f8';
                localStorage.setItem('theme', 'day');
            }
        }

        function setActiveSectionBeforeSubmit(sectionName) {
            localStorage.setItem('activeSection', sectionName);
        }

        function activateMovieModeBeforeSubmit() {
    localStorage.setItem('activeSection', 'scene');
    localStorage.setItem('theme', 'night');

    document.documentElement.classList.add('night-mode');
    document.documentElement.style.backgroundColor = '#0f172a';
}

        function showSection(sectionName) {
            var sections = document.querySelectorAll('.page-section');
            var navItems = document.querySelectorAll('.nav-item');

            sections.forEach(function (section) {
                section.classList.remove('active');
            });

            navItems.forEach(function (item) {
                item.classList.remove('active');
            });

            var targetSection = document.getElementById('section-' + sectionName);
            var targetNav = document.getElementById('nav-' + sectionName);

            if (targetSection) {
                targetSection.classList.add('active');
            }

            if (targetNav) {
                targetNav.classList.add('active');
            }

            localStorage.setItem('activeSection', sectionName);
            updatePanelTitle(sectionName);
        }

        function updatePanelTitle(sectionName) {
            var title = document.getElementById('panelTitle');
            var subtitle = document.getElementById('panelSubtitle');

            if (!title || !subtitle) {
                return;
            }

            if (sectionName === 'general') {
                title.innerHTML = "Akıllı Ev Kontrol Paneli";
                subtitle.innerHTML = "Oturma Odası · 4 cihaz aktif · Otomasyon: <span style='color:var(--success-green); font-weight:600;'><i class='fa-solid fa-circle-check'></i> Açık</span>";
            }

            if (sectionName === 'sensor') {
                title.innerHTML = "Sensör Paneli";
                subtitle.innerHTML = "Sıcaklık, nem ve bağlantı verileri";
            }

            if (sectionName === 'lighting') {
                title.innerHTML = "Aydınlatma Paneli";
                subtitle.innerHTML = "Tüm odaların parlaklığını ayrı ayrı ayarla";
            }

            if (sectionName === 'scene') {
                title.innerHTML = "Sahne Modları";
                subtitle.innerHTML = "Gündüz, gece ve özel ev modları";
            }

            if (sectionName === 'energy') {
                title.innerHTML = "Enerji Takibi";
                subtitle.innerHTML = "Anlık tüketim ve enerji durumu";
            }

            if (sectionName === 'settings') {
                title.innerHTML = "Sistem Ayarları";
                subtitle.innerHTML = "Panel, operatör ve bağlantı ayarları";
            }
        }

        function updateRoomLabel(roomName, value) {
            var label = document.getElementById('roomLabel' + roomName);

            if (label) {
                label.innerHTML = value;
            }
        }

        function submitRoomForm(roomName) {
            setActiveSectionBeforeSubmit('lighting');

            var form = document.getElementById('roomForm' + roomName);

            if (form) {
                form.submit();
            }
        }

        function setRoomBrightness(roomName, value) {
            var range = document.getElementById('roomBrightness' + roomName);

            if (range) {
                range.value = value;
                updateRoomLabel(roomName, value);
            }

            submitRoomForm(roomName);
        }

        document.addEventListener('DOMContentLoaded', function () {
            updateDateTime();
            setInterval(updateDateTime, 1000);

            var savedSection = localStorage.getItem('activeSection');

            if (!savedSection) {
                savedSection = 'general';
            }

            showSection(savedSection);
        });
    </script>

</body>
</html>