@model MovieApp.Web.Models.HomeStatus
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sistem Paneli | @Model.OperatorName</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        body { background-color: #f4f6f9; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .card { transition: transform 0.2s; }
        .card:hover { transform: translateY(-5px); }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow mb-4">
        <div class="container">
            <span class="navbar-brand fw-bold">
                <i class="bi bi-cpu-fill text-primary"></i> Akıllı Ev Kontrol Paneli
            </span>
            <div class="d-flex text-white">
                <span class="me-3"><i class="bi bi-person-badge"></i> Operatör: @Model.OperatorName</span>
                
            </div>
        </div>
    </nav>

    <div class="container">
        
        <div class="row mb-4">
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body d-flex justify-content-around bg-white rounded-4">
                        <div class="text-center">
                            <h6 class="text-muted"><i class="bi bi-wifi text-success"></i> Sinyal</h6>
                            <h5 class="mb-0 fw-bold">@Model.ConnectionQuality</h5>
                        </div>
                        <div class="text-center border-start border-end px-5">
                            <h6 class="text-muted"><i class="bi bi-droplet-half text-info"></i> Ortam Nemi</h6>
                            <h5 class="mb-0 fw-bold">%@Model.Humidity</h5>
                        </div>
                        <div class="text-center">
                            <h6 class="text-muted"><i class="bi bi-clock-history"></i> Son Senkronizasyon</h6>
                            <h5 class="mb-0 fw-bold">@Model.LastSyncTime</h5>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            
            <div class="col-md-4 mb-4">
                <div class="card shadow border-0 bg-white rounded-4 h-100">
                    <div class="card-body p-4">
                        <h5 class="card-title text-secondary border-bottom pb-2"><i class="bi bi-thermometer-sun text-danger"></i> Sıcaklık</h5>
                        
                        <div class="text-center my-4">
                            <h1 class="display-2 fw-bold text-dark">@Model.Temperature<span class="fs-4 text-muted">°C</span></h1>
                        </div>

                        <div class="progress mt-4" style="height: 15px;">
                            <div class="progress-bar bg-danger progress-bar-striped progress-bar-animated" role="progressbar" style="width: @(Model.Temperature * 2)%" aria-valuenow="@Model.Temperature" aria-valuemin="0" aria-valuemax="50"></div>
                        </div>
                        <div class="d-flex justify-content-between mt-1 text-muted small">
                            <span>0°C</span>
                            <span>50°C</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card shadow border-0 rounded-4 h-100 @(Model.IsLightOn ? "bg-white text-dark" : "bg-dark text-white")">
                    <div class="card-body text-center p-4">
                        <h5 class="card-title border-bottom pb-2 @(Model.IsLightOn ? "border-light" : "border-secondary")">
                            <i class="bi bi-lightbulb@(Model.IsLightOn ? "-fill text-warning" : "")"></i> Aydınlatma
                        </h5>
                        
                        <div class="my-4">
                            <span class="badge rounded-pill fs-5 @(Model.IsLightOn ? "bg-success" : "bg-secondary") mb-3">
                                <i class="bi bi-power"></i> @(Model.IsLightOn ? "DEVREDE" : "KAPALI")
                            </span>
                        </div>

                       
                        <form method="post" action="/Home/ToggleLight">
                            <input type="hidden" name="currentState" value="@Model.IsLightOn.ToString()" />
                            <button type="submit" class="btn fw-bold w-100 shadow-sm py-3 fs-5 @(Model.IsLightOn ? "btn-dark text-white" : "btn-warning text-dark")">
                                <i class="bi @(Model.IsLightOn ? "bi-toggle-on" : "bi-toggle-off")"></i> @(Model.IsLightOn ? "Sistemi Kapat" : "Sistemi Aç")
                            </button>
                        </form>
                    </div>
                </div>
            </div>

          <!-- Havalandırma Kartı (Süreli Sistem) -->
<div class="col-md-4 mb-4">
    
    <div id="motorCard" class="card shadow border-0 rounded-4 h-100 @(Model.IsMotorRunning ? "bg-primary text-white" : "bg-white text-dark")">
        <div class="card-body text-center p-4">
            <h5 class="card-title border-bottom pb-2"><i class="bi bi-fan @(Model.IsMotorRunning ? "fa-spin" : "")"></i> Fan Motoru</h5>
            
            <!-- id="motorDurumYazisi" -> id="motorStatusText" oldu -->
            <h2 id="motorStatusText" class="fw-bold my-3 text-uppercase tracking-wider">
                @(Model.IsMotorRunning ? "ÇALIŞIYOR" : "Beklemede")
            </h2>

            <form method="post" action="/Home/ToggleMotor">
                <div class="input-group mb-3 px-3 @(Model.IsMotorRunning ? "d-none" : "")">
                    <input type="number" name="minutesInput" class="form-control text-center bg-light border-0" value="@Model.SetMinutes" min="1" max="60">
                    <span class="input-group-text border-0 bg-secondary text-white">Dk</span>
                </div>

                <button type="submit" class="btn fw-bold w-100 shadow-sm py-3 fs-5 @(Model.IsMotorRunning ? "btn-light text-primary" : "btn-primary text-white")">
                    <i class="bi @(Model.IsMotorRunning ? "bi-stop-circle" : "bi-play-circle")"></i> @(Model.IsMotorRunning ? "Motoru Durdur" : "Başlat")
                </button>
            </form>

            <div class="mt-4 p-2 rounded-3 @(Model.IsMotorRunning ? "bg-light text-primary" : "bg-light text-secondary")">
                <!-- id="sayacDegeri" -> id="timerValue" oldu -->
                <h5 class="mb-0 fw-bold"><i class="bi bi-stopwatch"></i> Kalan: <span id="timerValue">00:00</span></h5>
            </div>
        </div>
    </div>
</div>

        </div>
    </div>

  
    <script>
    var isSystemOn = '@Model.IsMotorRunning'.toLowerCase() === 'true';
    var totalSeconds = @Model.Countdown; 
    var setSeconds = totalSeconds; 
    var isPhysicalMotorActive = true; 

    if (isSystemOn) {
        var timer = setInterval(function () {
            totalSeconds--;

            var min = Math.floor(totalSeconds / 60);
            var sec = totalSeconds % 60;
            var formattedTime = (min < 10 ? "0" + min : min) + ":" + (sec < 10 ? "0" + sec : sec);

            if (isPhysicalMotorActive) {
                
                document.getElementById("timerValue").innerText = formattedTime;
                document.getElementById("motorStatusText").innerText = "ÇALIŞIYOR";
                document.getElementById("motorCard").className = "card shadow border-0 rounded-4 h-100 bg-primary text-white";
            } else {
                document.getElementById("timerValue").innerText = formattedTime + " (Soğutma)";
                document.getElementById("motorStatusText").innerText = "DİNLENİYOR";
                document.getElementById("motorCard").className = "card shadow border-0 rounded-4 h-100 bg-warning text-dark";
            }

            if (totalSeconds <= 0) {
                isPhysicalMotorActive = !isPhysicalMotorActive; 
                totalSeconds = setSeconds; 
            }
            
        }, 1000); 
    } else {
         document.getElementById("timerValue").innerText = "--:--";
    }

</script>
</body>
</html>